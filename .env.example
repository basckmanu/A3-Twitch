# Copie ce fichier en `.env` et remplis les valeurs. Ne commit jamais `.env`.

# Twitch (chat + API Helix)
TOKEN_TWITCH=oauth:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CHANNELS=channel1,channel2
CHANNEL_ID=123456789,987654321

CLIENT_ID=
CLIENT_SECRET=

# Discord
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
# IDs Discord (séparés par des virgules) autorisés à cliquer garder/highlight/supprimer.
# Laisser vide = accès non restreint à TOUT utilisateur ayant accès au salon Discord.
# Active le mode développeur Discord (Paramètres > Avancés) pour copier un ID utilisateur.
DISCORD_ALLOWED_USERS=

# PostgreSQL
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=a3user
DB_PASSWORD=
DB_NAME=a3_db
DB_SSLMODE=prefer

# Privacy / RGPD — secret utilisé pour pseudonymiser (SHA-256) les pseudos Twitch et les
# reviewers Discord avant stockage. DOIT être une valeur aléatoire forte et unique par
# déploiement (ex: `python -c "import secrets; print(secrets.token_hex(32))"`).
# Ne JAMAIS laisser une valeur par défaut/prévisible : un salt connu permet de reconstruire
# un rainbow table sur l'espace des pseudos Twitch et de désanonymiser tout le monde.
A3_HASH_SALT=
